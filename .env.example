# GHL-TOOLKIT Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# GoHighLevel API v2 (Required)
# Get your Private Integration Token from GHL Settings → Integrations
GHL_API_KEY=pit-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Get your Location ID from GHL Settings → Business Profile
GHL_LOCATION_ID=xxxxxxxxxxxxxxxxxxxxxxxx

# Meta Conversions API (Optional - for /ghl-capi)
META_PIXEL_ID=xxxxxxxxxxxxxxxxx
META_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase (Optional - for edge functions)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
